# Ignore everything by default
*
*/

# Explicitly track these files
!.gitignore
!LICENSE
!README.md
!THIRD_PARTY_NOTICES.md
!run_nestapp.m

# Source files
!src/
!src/*.m
!src/*.png
!src/*.jpg
!src/templates/
!src/templates/*.mat
!src/@nestapp/
!src/@nestapp/*.m
!src/qa/
!src/qa/*.m
!src/io/
!src/io/*.m

# Tests (develop branch only)
!tests/
!tests/unit/
!tests/unit/*.m
!tests/integration/
!tests/integration/*.m
!tests/regression/
!tests/regression/*.m
!tests/helpers/
!tests/helpers/*.m
!tests/*.m

# CI
!.github/
!.github/workflows/
!.github/workflows/*.yml
